---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FOOTER_SERVICES } from '../data/site';

const title = 'Sayfa Bulunamadı (404) | Akcolor Fotoğrafçılık';
const description = 'Aradığınız sayfa bulunamadı. Akcolor Fotoğrafçılık hizmetlerine ana sayfadan ulaşabilirsiniz.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="section notfound">
    <div class="container">
      <p class="code">404</p>
      <h1>Sayfa bulunamadı</h1>
      <p class="lead">
        Aradığınız sayfa taşınmış veya kaldırılmış olabilir. Aşağıdaki bağlantılardan devam edebilirsiniz.
      </p>
      <div class="actions">
        <a href="/" class="btn btn-primary">Ana Sayfaya Dön</a>
        <a href="/sss/" class="btn btn-secondary">Sıkça Sorulan Sorular</a>
      </div>
      <ul class="links">
        {FOOTER_SERVICES.map((s) => (
          <li><a href={s.href}>{s.label}</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding-top: 8rem;
    text-align: center;
    min-height: 70vh;
  }

  .code {
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: 700;
    color: var(--accent-primary);
    line-height: 1;
  }

  .notfound h1 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin: 0.5rem 0 1rem;
  }

  .lead {
    color: var(--text-secondary);
    max-width: 46ch;
    margin: 0 auto 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    justify-content: center;
  }
</style>
